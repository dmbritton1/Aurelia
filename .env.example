# Copy to .env.local and fill in. .env.local is gitignored.

# Optional: NewsAPI key for better article fetching (falls back to Google News RSS without it)
NEWS_API_KEY=your_newsapi_key_here

# Required: secret used to sign session JWTs (use a random string, 32+ chars)
JWT_SECRET=change-this-to-a-random-secret-string-at-least-32-chars

# Twilio — used to text newsletters to users who add a phone number on the Dashboard.
# Find these at https://console.twilio.com (Account SID + Auth Token on the homepage;
# the from-number must be an SMS-capable number you own). Leave blank to disable SMS.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Resend — used to email newsletters to users who enable email delivery.
# Get an API key at https://resend.com. EMAIL_FROM defaults to Resend's
# onboarding sender (onboarding@resend.dev) which only delivers to your Resend
# signup address until you verify a sending domain. Leave RESEND_API_KEY blank
# to disable email.
RESEND_API_KEY=
EMAIL_FROM=Aurelia <onboarding@resend.dev>
